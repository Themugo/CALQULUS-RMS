{
  "name": "rentflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:financial": "vitest run src/test/financial-integrity",
    "test:isolation": "vitest run src/test/isolation",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:load:payment": "k6 run src/load-tests/payment-callback.js",
    "test:load:statement": "k6 run src/load-tests/statement-generation.js",
    "test:load:messaging": "k6 run src/load-tests/messaging.js",
    "test:load:all": "k6 run src/load-tests/payment-callback.js && k6 run src/load-tests/statement-generation.js && k6 run src/load-tests/messaging.js",
    "test:all": "npm run test && npm run test:financial && npm run test:isolation && npm run test:e2e:ci",
    "audit:prod": "node scripts/audit-production.mjs",
    "release:report": "node scripts/release-readiness-report.mjs",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test:all && npm run build && npm audit --audit-level=high && npm run audit:prod",
    "preview": "vite preview"
  },
