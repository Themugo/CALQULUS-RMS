# ============================================================
# RentFlow — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
# In Supabase Auth settings, add these redirect URLs:
# https://yourdomain.com/reset-password
# https://yourdomain.com/landlord
# https://yourdomain.com/landlord/login
# https://yourdomain.com/tenant/login
# https://yourdomain.com/webhost/login

# ── Demo controls (staging/demo only; keep false in production) ──
VITE_ENABLE_PUBLIC_DEMO=false
VITE_ENABLE_DEMO_SEED=false
VITE_DEMO_SEED_SECRET=

# ── Test/dev tuning ────────────────────────────────────────────────
# Optional. Keep unset in production unless support asks you to tune it.
VITE_AUTH_TIMEOUT_MS=

# ── E2E Test Environment (for Playwright tests) ───────────────────────
# Set these to run full E2E test suite with authentication flows
# Use test accounts only - never use production credentials
E2E_MANAGER_EMAIL=
E2E_MANAGER_PASSWORD=
E2E_TENANT_EMAIL=
E2E_TENANT_PASSWORD=

# ── Error tracking (optional but strongly recommended in production) ─
# Leave blank to disable Sentry. When set, the lazy loader pulls in the
# Sentry browser SDK at runtime and forwards errors logged via the
# shared errorLogger. Source maps are emitted as `hidden` so they can be
# uploaded to Sentry without shipping to end users.
#
#   1. Install:  npm i @sentry/browser
#   2. Set VITE_SENTRY_DSN below
#   3. Upload source maps in CI after `vite build`
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_APP_VERSION=

# ── Supabase Edge Function Secrets (set in Supabase Dashboard) ─
# These are NOT in the frontend — set them in:
# Supabase Dashboard → Edge Functions → Secrets
#
# SUPABASE_SERVICE_ROLE_KEY=   (auto-set by Supabase)
# RESEND_API_KEY=              Email delivery (resend.com)
# RESEND_FROM_DOMAIN=          Verified sending domain, e.g. rentflow.ink
# RESEND_FROM_EMAIL=           Verified sender, e.g. RentFlow <noreply@rentflow.ink>
# SENDGRID_API_KEY=            Email delivery (sendgrid.net)
# MPESA_CONSUMER_KEY=          Safaricom Daraja API
# MPESA_CONSUMER_SECRET=       Safaricom Daraja API
# MPESA_PASSKEY=               Safaricom STK Push passkey
# MPESA_SHORTCODE=             Paybill / Till number
# MPESA_CALLBACK_SECRET=       Webhook validation secret
# MPESA_ENV=production         or 'sandbox' for testing
# SMS_PROVIDER=twilio          Optional: twilio or africastalking. Defaults to Twilio when configured.
# SMS_FALLBACK_PROVIDER=       Optional: set to africastalking to fall back if Twilio fails.
# TWILIO_ACCOUNT_SID=          Twilio SMS/WhatsApp account SID
# TWILIO_AUTH_TOKEN=           Twilio auth token
# TWILIO_FROM_NUMBER=          Twilio SMS sender, e.g. +15551234567
# TWILIO_MESSAGING_SERVICE_SID=Optional Twilio Messaging Service SID instead of FROM number
# AT_API_KEY=                  Africa's Talking SMS fallback
# AT_USERNAME=                 Africa's Talking username fallback
# AFRICASTALKING_API_KEY=      Africa's Talking SMS/WhatsApp fallback
# AFRICASTALKING_USERNAME=     Africa's Talking username fallback
# SITE_URL=https://yourdomain.com
# APP_URL=https://yourdomain.com
# DEMO_SECRET=                 Strong random secret for staging/demo seed only
# BOOTSTRAP_SECRET=            One-time webhost bootstrap secret
# STRIPE_SECRET_KEY=           Stripe API key (server-side only)
# STRIPE_WEBHOOK_SECRET=       Stripe webhook signing secret
# PAYSTACK_SECRET_KEY=         Paystack API key (if using Paystack)
# LOVABLE_API_KEY=             AI document/receipt parsing
# TWILIO_WHATSAPP_FROM=        Twilio WhatsApp sender
# META_WHATSAPP_TOKEN=         Meta WhatsApp Cloud API token
# META_PHONE_NUMBER_ID=        Meta WhatsApp Cloud phone number id
# WHATSAPP_ACCESS_TOKEN=       Legacy WhatsApp token
# PHONE_NUMBER_ID=             Legacy WhatsApp phone number id
